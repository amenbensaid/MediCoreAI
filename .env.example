# Runtime ports
FRONTEND_PORT=3100
BACKEND_PORT=5101
API_INTERNAL_PORT=5000
POSTGRES_PORT=5432

# PostgreSQL
POSTGRES_USER=medicore_user
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_DB=medicore_db

# Backend
NODE_ENV=production
DATABASE_URL=postgresql://medicore_user:change_me_postgres_password@postgres:5432/medicore_db
JWT_SECRET=change_me_with_a_long_random_secret
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:3100
CORS_ORIGINS=http://localhost:3100,http://localhost:5173

# Jitsi Meet integration
JITSI_BASE_URL=https://meet.jit.si
JITSI_ROOM_PREFIX=medicore
JITSI_ROOM_SECRET=change_me_jitsi_room_secret

# Optional Google Calendar integration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5101/api/users/google-calendar/callback
