NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://medicore_user:change_me_postgres_password@localhost:5432/medicore_db
JWT_SECRET=change_me_with_a_long_random_secret
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:3100

# Jitsi Meet integration
JITSI_BASE_URL=https://meet.jit.si
JITSI_ROOM_PREFIX=medicore
JITSI_ROOM_SECRET=change_me_jitsi_room_secret

# Optional Google Calendar integration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5000/api/users/google-calendar/callback
